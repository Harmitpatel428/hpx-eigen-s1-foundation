DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hpx_eigen_local"
JWT_SECRET="local-dev-secret-123"
NODE_ENV="development"
PORT=3000

# AWS SES / Render Email Environment Variables
# These must be configured in Render for production email delivery
SES_REGION="us-east-1"
SES_FROM_EMAIL="noreply@yourdomain.com"
FRONTEND_URL="http://localhost:5173"

# Note for Render: AWS SDK automatically uses AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY if available.
# Otherwise, IAM roles (if hosted on AWS) or these standard AWS env vars are required.
