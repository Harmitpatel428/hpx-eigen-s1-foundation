datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// ═══════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════

enum SessionStatus {
  CREATED
  ACTIVE
  EXPIRED
  INVALIDATED
  REVOKED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  FAILED
}

enum UserStatus {
  NEW
  PENDING_ACTIVATION
  INVITED
  ACTIVE
  SUSPENDED
  TERMINATED
}

// ABAC scope bound to a UserRole assignment.
// OWN          = user sees only records they own
// TEAM         = user sees all records owned by teammates
// DEPARTMENT   = user sees all records owned by departmental members
// ORGANIZATION = user sees all records in the tenant
enum ScopeType {
  OWN
  TEAM
  DEPARTMENT
  ORGANIZATION
}

// ═══════════════════════════════════════════════════════════════════
// S1 FOUNDATION — AUTH, USERS, ROLES, SESSIONS
// ═══════════════════════════════════════════════════════════════════

model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  subscriptionPlanId String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  roles           Role[]
  users           User[]
  userInvitations UserInvitation[]
  sessions        Session[]
  opportunityTypes OpportunityType[]
  departments     Department[]
  teams           Team[]

  @@index([deletedAt])
}

// ─── Organizational Hierarchy ─────────────────────────────────────

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  parentId  String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users   User[]

  @@index([tenantId])
}

model Team {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  departmentId String? @db.Uuid
  name         String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@index([tenantId, departmentId])
}

// ─── Roles & Permissions ──────────────────────────────────────────

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  users           UserRole[]
  userInvitations UserInvitation[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

// Global permissions (not tenant-scoped).
// Slugs are the canonical reference: "lead:view", "contact:create", etc.
model Permission {
  id          String @id @default(uuid()) @db.Uuid
  slug        String @unique
  module      String
  description String

  roles RolePermission[]
}

// Junction table — composite PK, NO soft-delete (physical deletes only).
model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// Junction table — composite PK, NO soft-delete (physical deletes only).
// scopeType determines ABAC data-access scope for this role assignment.
model UserRole {
  userId    String    @db.Uuid
  roleId    String    @db.Uuid
  scopeType ScopeType @default(OWN)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
}

// ─── Users ────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid()) @db.Uuid
  tenantId          String     @db.Uuid
  email             String
  emailVerified     DateTime?
  password          String
  status            UserStatus @default(NEW)
  teamId            String?    @db.Uuid
  departmentId      String?    @db.Uuid
  suspendedAt       DateTime?
  suspensionReason  String?
  terminatedAt      DateTime?
  terminationReason String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  team                Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  department          Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sessions            Session[]
  userRoles           UserRole[]
  invitedUsers        UserInvitation[] @relation("InvitedBy")
  acceptedInvitations UserInvitation[] @relation("AcceptedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
  @@index([teamId, deletedAt])
  @@index([departmentId, deletedAt])
}

model UserInvitation {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @db.Uuid
  email       String
  status      InvitationStatus @default(PENDING)
  roleId      String           @db.Uuid
  token       String           @unique
  expiresAt   DateTime
  invitedBy   String           @db.Uuid
  acceptedBy  String?          @db.Uuid
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  inviter  User    @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Restrict)
  acceptor User?   @relation("AcceptedBy", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@index([token])
  @@index([deletedAt])
}

model Session {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @db.Uuid
  userId           String        @db.Uuid
  status           SessionStatus @default(CREATED)
  refreshTokenHash String
  expiresAt        DateTime
  lastActivityAt   DateTime?
  revokedAt        DateTime?
  invalidatedAt    DateTime?
  expiredAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([tenantId, userId, status])
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  eventType      String
  entityType     String
  entityId       String
  actorUserId    String?  @db.Uuid
  actorIp        String?
  actorUserAgent String?
  operation      String
  payload        Json
  previousHash   String?  @db.Char(64)
  currentHash    String   @db.Char(64)
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([currentHash])
}

// ═══════════════════════════════════════════════════════════════════
// S2 CRM DOMAIN
// ═══════════════════════════════════════════════════════════════════

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EMAIL_CAMPAIGN
  SOCIAL_MEDIA
  TRADE_SHOW
  OTHER
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum OpportunityCurrency {
  INR
  USD
  EUR
  GBP
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
}

// ─── Lead ─────────────────────────────────────────────────────────
model Lead {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @db.Uuid
  firstName     String
  lastName      String
  email         String?
  phone         String?
  company       String?
  source        LeadSource @default(OTHER)
  status        LeadStatus @default(NEW)
  stage         LeadStage  @default(NEW)
  score         Int        @default(0)
  expectedValue Decimal    @default(0) @db.Decimal(18, 2)
  ownerId       String?    @db.Uuid
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  contacts      Contact[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([deletedAt])
}

// ─── Contact ──────────────────────────────────────────────────────
model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  leadId    String?  @db.Uuid
  firstName String
  lastName  String
  email     String?
  phone     String?
  title     String?
  company   String?
  ownerId   String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, ownerId])
  @@index([deletedAt])
}

// ─── OpportunityType ──────────────────────────────────────────────
model OpportunityType {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
}

// ─── Opportunity ──────────────────────────────────────────────────
model Opportunity {
  id                    String              @id @default(uuid()) @db.Uuid
  tenantId              String              @db.Uuid
  leadId                String              @db.Uuid
  contactId             String?             @db.Uuid
  ownerId               String              @db.Uuid
  opportunityTypeId     String?             @db.Uuid
  customOpportunityType String?
  title                 String
  value                 Decimal             @db.Decimal(18, 2)
  currency              OpportunityCurrency @default(INR)
  stage                 OpportunityStage    @default(PROSPECTING)
  expectedCloseDate     DateTime?
  closedAt              DateTime?
  lostReason            String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Restrict)
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityType OpportunityType? @relation(fields: [opportunityTypeId], references: [id], onDelete: Restrict)
  activities      Activity[]
  pipeline        Pipeline[]
  invoices        Invoice[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, ownerId])
  @@index([tenantId, opportunityTypeId])
  @@index([tenantId, expectedCloseDate])
  @@index([deletedAt])
}

// ─── Activity ─────────────────────────────────────────────────────
model Activity {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  opportunityId String       @db.Uuid
  userId        String       @db.Uuid
  type          ActivityType
  subject       String
  notes         String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, userId])
  @@index([tenantId, type])
  @@index([deletedAt])
}

// ─── Pipeline ─────────────────────────────────────────────────────
model Pipeline {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  opportunityId String           @db.Uuid
  stage         OpportunityStage
  enteredAt     DateTime         @default(now())
  exitedAt      DateTime?
  durationDays  Int?
  createdAt     DateTime         @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, stage])
}

// ═══════════════════════════════════════════════════════════════════
// S3 FINANCE DOMAIN
// ═══════════════════════════════════════════════════════════════════

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  UPI
  CHEQUE
  CASH
  NEFT
  RTGS
  IMPS
  OTHER
}

enum PaymentStatus {
  PENDING
  RECEIVED
  FAILED
  REFUNDED
  CANCELLED
}

// ─── Invoice ──────────────────────────────────────────────────────
model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  opportunityId   String        @db.Uuid
  invoiceNumber   String?
  invoiceDate     DateTime      @default(now())
  amount          Decimal       @db.Decimal(18, 2)
  taxPercentage   Decimal?      @default(0) @db.Decimal(5, 2)
  discount        Decimal?      @default(0) @db.Decimal(18, 2)
  otherCharges    Decimal?      @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal?      @default(0) @db.Decimal(18, 2)
  totalAmount     Decimal       @db.Decimal(18, 2)
  paymentTerms    String?
  internalNotes   String?
  invoiceNotes    String?
  termsConditions String?
  attachments     String[]      @default([])
  status          InvoiceStatus @default(DRAFT)
  dueDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  payments    Payment[]

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

// ─── Payment ──────────────────────────────────────────────────────
model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  invoiceId       String        @db.Uuid
  amount          Decimal       @db.Decimal(18, 2)
  method          PaymentMethod @default(CASH)
  referenceNumber String?
  bankName        String?
  chequeNumber    String?
  status          PaymentStatus @default(PENDING)
  receivedBy      String?
  notes           String?
  attachmentUrl   String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([deletedAt])
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
